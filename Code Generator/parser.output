Terminals unused in grammar

    TOKEN_ERROR


Grammar

    0 $accept: program $end

    1 program: stmt_list

    2 stmt_list: stmt_list stmt
    3          | stmt

    4 stmt: decl
    5     | TOKEN_IDENT TOKEN_ASSIGN expr TOKEN_SEMICOLON
    6     | TOKEN_MATRIX TOKEN_LBRACKET expr TOKEN_RBRACKET TOKEN_LBRACKET expr TOKEN_RBRACKET TOKEN_ASSIGN expr TOKEN_SEMICOLON
    7     | TOKEN_PRINT expr TOKEN_SEMICOLON
    8     | block

    9 decl: type TOKEN_IDENT TOKEN_ASSIGN expr TOKEN_SEMICOLON
   10     | type TOKEN_IDENT TOKEN_LPAREN param_list_opt TOKEN_RPAREN block

   11 param_list_opt: param_list
   12               | %empty

   13 param_list: param
   14           | param TOKEN_COMMA param_list

   15 param: type TOKEN_IDENT

   16 block: TOKEN_LBRACE stmt_list TOKEN_RBRACE

   17 expr: expr TOKEN_PLUS term
   18     | expr TOKEN_MINUS term
   19     | term

   20 term: term TOKEN_MUL factor
   21     | term TOKEN_DIV factor
   22     | factor

   23 factor: TOKEN_NUMBER
   24       | TOKEN_FLOAT_NUMBER
   25       | TOKEN_IDENT
   26       | TOKEN_MATRIX TOKEN_LBRACKET expr TOKEN_RBRACKET TOKEN_LBRACKET expr TOKEN_RBRACKET
   27       | TOKEN_LPAREN expr TOKEN_RPAREN

   28 type: TOKEN_INT
   29     | TOKEN_FLOAT


